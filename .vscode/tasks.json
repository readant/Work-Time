{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true,
      "label": "esbuild: 监听",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$esbuild",
      "label": "esbuild: 构建",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "lint",
      "problemMatcher": "$tsc",
      "label": "tsc: 类型检查",
      "group": "build"
    }
  ]
}
